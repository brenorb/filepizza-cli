{
  "name": "filepizza-cli",
  "version": "0.1.0",
  "description": "Programmatic FilePizza uploader CLI compatible with https://file.pizza/",
  "type": "module",
  "bin": {
    "filepizza": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "filepizza",
    "cli",
    "webrtc",
    "peerjs"
  ],
  "author": "Breno Brito <brenorb@gmail.com>",
  "license": "BSD-3-Clause",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "peerjs": "^1.5.5",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
